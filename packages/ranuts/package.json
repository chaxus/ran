{
  "name": "ranuts",
  "version": "1.0.0-beta-1",
  "description": "lib",
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "type": "module",
  "types": "dist/index.d.ts",
  "engines": {
    "node": ">=23.10.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/umd/index.umd.cjs"
    },
    "./node": {
      "types": "./dist/src/node/index.d.ts",
      "import": "./dist/src/node/index.js",
      "require": "./dist/umd/node/node.umd.cjs"
    },
    "./utils": {
      "types": "./dist/src/utils/index.d.ts",
      "import": "./dist/src/utils/index.js",
      "require": "./dist/umd/utils/utils.umd.cjs"
    },
    "./visual": {
      "types": "./dist/src/utils/visual/index.d.ts",
      "import": "./dist/src/utils/visual/index.js"
    },
    "./vnode": {
      "types": "./dist/src/vnode/index.d.ts",
      "import": "./dist/src/vnode/index.js"
    },
    "./wicket": {
      "types": "./dist/src/wicket/index.d.ts",
      "import": "./dist/src/wicket/index.js"
    },
    "./arithmetic": {
      "types": "./dist/src/arithmetic/index.d.ts",
      "import": "./dist/src/arithmetic/index.js"
    },
    "./sort": {
      "types": "./dist/src/sort/index.d.ts",
      "import": "./dist/src/sort/index.js"
    },
    "./optimize": {
      "types": "./dist/src/optimize/index.d.ts",
      "import": "./dist/src/optimize/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chaxus/ran.git",
    "directory": "packages/ranuts"
  },
  "bugs": {
    "url": "https://github.com/chaxus/ran/issues"
  },
  "homepage": "https://github.com/chaxus/ran/tree/main/packages/ranuts/docs",
  "files": [
    "dist",
    "typings.d.ts"
  ],
  "scripts": {
    "build": "sh ./bin/build.sh",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit",
    "dev": "vite --host",
    "prepublish": "npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@types/earcut": "^3.0.0",
    "@types/node": "^25.3.5",
    "@vitest/coverage-v8": "^4.1.7",
    "@webgpu/types": "^0.1.69",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "earcut": "^3.0.2",
    "jschardet": "^3.1.4",
    "magic-string": "^0.30.21"
  }
}
